# Notion インテグレーショントークン
# Notion → 設定 → コネクト → 新しいインテグレーションを作成
# データベースのページでインテグレーションを接続してください
NOTION_API_KEY=secret_your_integration_token_here

# Notion データベースID
# データベースURLの notion.so/xxxxxxxx?v=... の x 部分（ハイフンあり・なし両対応）
NOTION_DATABASE_ID=your_database_id_here

# Notionデータベースのプロパティ名（実際のプロパティ名に合わせて変更）
NOTION_PROP_NAME=著者名
NOTION_PROP_BIRTH=生年
NOTION_PROP_DEATH=没年
NOTION_PROP_CATEGORY=ジャンル

# サーバーポート（省略時は3000）
PORT=3000

{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "functions": { "model/**/*.js": {} },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/model/$1" },
    { "source": "/", "destination": "/view/pages/top/index.html" },
